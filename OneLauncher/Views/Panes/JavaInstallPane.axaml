<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OneLauncher.Views.Panes.PaneViewModels"
             mc:Ignorable="d"
             d:DesignWidth="650"
             d:DesignHeight="620"
             x:DataType="vm:JavaInstallPaneViewModel"
             x:CompileBindings="True"
             x:Class="OneLauncher.Views.Panes.JavaInstallPane">
    <Grid RowDefinitions="Auto,Auto,*" Margin="20">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
            <Button Grid.Column="0" Command="{Binding CloseCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Image Source="/Assets/icos/back.png" Width="20" Height="20"/>
                    <TextBlock Text="返回" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock Grid.Column="1"
                       Text="安装 Java"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"/>
        </Grid>

        <Separator Grid.Row="1" Margin="0,16"/>

        <StackPanel Grid.Row="2" Spacing="12" MaxWidth="420" HorizontalAlignment="Center">
            <TextBlock Text="Java 版本"/>
            <ComboBox ItemsSource="{Binding JavaVersions}"
                      SelectedItem="{Binding SelectedJavaVersion}"
                      IsEnabled="{Binding !IsInstalling}"/>

            <TextBlock Text="提供商" Margin="0,8,0,0"/>
            <ComboBox ItemsSource="{Binding JavaProviders}"
                      SelectedItem="{Binding SelectedJavaProvider}"
                      IsEnabled="{Binding !IsInstalling}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:JavaProviderItem">
                        <TextBlock Text="{Binding DisplayName}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="{Binding InstalledVersionsText}" Opacity="0.72" Margin="0,8,0,0"/>
            <TextBlock Text="所选版本已经配置，可选择覆盖安装"
                       IsVisible="{Binding IsSelectedVersionInstalled}"/>

            <ProgressBar Minimum="0"
                         Maximum="28"
                         Value="{Binding ProgressValue}"
                         Height="18"
                         Margin="0,12,0,0"/>
            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap"/>

            <Button Content="安装"
                    Command="{Binding InstallCommand}"
                    IsVisible="{Binding !IsSelectedVersionInstalled}"
                    HorizontalAlignment="Stretch"
                    Margin="0,8,0,0"/>
            <Button Content="覆盖安装"
                    Command="{Binding OverwriteCommand}"
                    IsVisible="{Binding IsSelectedVersionInstalled}"
                    HorizontalAlignment="Stretch"
                    Margin="0,8,0,0"/>
            <Button Content="取消"
                    Command="{Binding CancelCommand}"
                    HorizontalAlignment="Stretch"/>
        </StackPanel>
    </Grid>
</UserControl>
