<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OneLauncher.Views.Panes.PaneViewModels"
             xmlns:lo="clr-namespace:OneLauncher.Core.Helper.Models;assembly=OneLauncher.Core"
             mc:Ignorable="d" d:DesignWidth="650" d:DesignHeight="620"
             x:DataType="vm:NewGameDataPaneViewModel"
             x:CompileBindings="True"
             x:Class="OneLauncher.Views.Panes.NewGameDataPane">
    <UserControl.Styles>
        <StyleInclude Source="avares://OneLauncher/Views/Styles/Pane.axaml"/>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="20">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
            <Button Classes="pane-toolbar" Command="{Binding CancelCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Image Source="/Assets/icos/back.png" Width="20" Height="20"/>
                    <TextBlock Text="返回" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock Grid.Column="1" Classes="pane-title" Text="新建游戏数据" Margin="14,0,0,0"/>
        </Grid>
        <Separator Grid.Row="1" Margin="0,16"/>

        <ScrollViewer Grid.Row="2">
            <StackPanel MaxWidth="520" HorizontalAlignment="Stretch" Spacing="16" Margin="0,0,0,20">
                <TextBlock Classes="pane-section-title" Text="基础版本"/>
                <Border Classes="pane-surface">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="pane-label" Text="游戏版本"/>
                        <ComboBox Classes="pane-field" ItemsSource="{Binding AvailableBaseVersions}"
                                  SelectedItem="{Binding SelectedBaseVersion}" PlaceholderText="选择已安装的游戏版本">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="lo:UserVersion">
                                    <TextBlock Text="{Binding VersionID}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <TextBlock Classes="pane-section-title" Text="实例信息"/>
                <Border Classes="pane-surface">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="pane-label" Text="实例名称"/>
                        <TextBox Classes="pane-field" Text="{Binding GameDataName}"
                                 IsEnabled="{Binding SelectedBaseVersion, Converter={x:Static ObjectConverters.IsNotNull}}"
                                 Watermark="例如：我的整合包"/>
                        <TextBlock Classes="pane-label" Text="模组加载器" Margin="0,8,0,0"/>
                        <ComboBox Classes="pane-field" ItemsSource="{Binding AvailableModLoaders}"
                                  SelectedItem="{Binding SelectedModLoader}"
                                  IsEnabled="{Binding SelectedBaseVersion, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="lo:ModEnum">
                                    <TextBlock Text="{Binding Converter={StaticResource ModEnumConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Classes="pane-label" Text="默认用户" Margin="0,8,0,0"/>
                        <ComboBox Classes="pane-field" ItemsSource="{Binding AvailableUsers}"
                                  SelectedItem="{Binding SelectedUser}"
                                  IsEnabled="{Binding SelectedBaseVersion, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="lo:UserModel">
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,16,0,0">
            <Button Grid.Column="0" Classes="pane-secondary" Content="取消" Command="{Binding CancelCommand}"/>
            <Button Grid.Column="1" Classes="pane-primary" Content="创建" Command="{Binding SaveCommand}"/>
        </Grid>
    </Grid>
</UserControl>
