<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OneLauncher.Views.Panes.PaneViewModels"
             xmlns:gdm="using:OneLauncher.Core.Global.ModelDataMangers"
             xmlns:models="using:OneLauncher.Core.Helper.Models"
             x:Class="OneLauncher.Views.Panes.EditGameDataPane"
             x:DataType="vm:EditGameDataPaneViewModel"
             x:CompileBindings="True"
             mc:Ignorable="d" d:DesignWidth="650" d:DesignHeight="620">
    <UserControl.Styles>
        <StyleInclude Source="avares://OneLauncher/Views/Styles/Pane.axaml"/>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="20">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
            <Button Classes="pane-toolbar" Command="{Binding CancelCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Image Source="/Assets/icos/back.png" Width="20" Height="20"/>
                    <TextBlock Text="返回" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock Grid.Column="1" Classes="pane-title" Text="编辑游戏数据" Margin="14,0,0,0"/>
        </Grid>
        <Separator Grid.Row="1" Margin="0,16"/>

        <ScrollViewer Grid.Row="2">
            <StackPanel MaxWidth="540" HorizontalAlignment="Stretch" Spacing="16" Margin="0,0,0,20">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Border Width="88" Height="88" CornerRadius="6" ClipToBounds="True"
                            Background="{DynamicResource CardBackgroundBrush}">
                        <Image Source="{Binding CurrentIcon}" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                        <TextBlock Classes="pane-section-title" Text="实例图标"/>
                        <TextBlock Classes="pane-help" Text="用于在游戏数据列表中识别此实例"/>
                        <Button Classes="pane-secondary" Content="更换图标" Command="{Binding ChangeIconCommand}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Grid>

                <TextBlock Classes="pane-section-title" Text="基本信息"/>
                <Border Classes="pane-surface">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="pane-label" Text="实例名称"/>
                        <TextBox Classes="pane-field" Text="{Binding InstanceName}"/>
                        <TextBlock Classes="pane-label" Text="默认登录用户" Margin="0,8,0,0"/>
                        <ComboBox Classes="pane-field" PlaceholderText="选择默认登录用户"
                                  ItemsSource="{Binding AvailableUsers}" SelectedItem="{Binding SelectedUser}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:UserModel">
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Classes="pane-label" Text="标签" Margin="0,8,0,0"/>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <ComboBox Classes="pane-field" PlaceholderText="选择可用标签"
                                      ItemsSource="{Binding AvailableTags}" SelectedItem="{Binding SelectedTag}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="gdm:GameDataTag">
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Column="1" Classes="pane-secondary" Content="清除"
                                    Command="{Binding ResetLabelOptionCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Classes="pane-section-title" Text="实例工具"/>
                <Border Classes="pane-surface">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="pane-secondary" Content="打开实例文件夹" Command="{Binding OpenInstanceFolderCommand}"/>
                        <Button Classes="pane-secondary" Content="创建桌面快捷启动" Command="{Binding AddToQuicklyPlayCommand}"/>
                        <Button Classes="pane-secondary" Content="复制此实例" Command="{Binding CopyThisInstanceCommand}"/>
                    </StackPanel>
                </Border>

                <TextBlock Classes="pane-section-title" Text="危险操作"/>
                <Button Classes="pane-danger" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <Image Source="/Assets/icos/del.png" Width="20" Height="20"/>
                        <TextBlock Text="移除此游戏数据"/>
                    </StackPanel>
                    <Button.Flyout>
                        <Flyout>
                            <StackPanel Width="320" Spacing="10">
                                <TextBlock Text="确认移除此游戏数据？" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Classes="pane-help" Text="实例记录和实例目录都将被删除，此操作无法撤销。"/>
                                <Separator/>
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                                    <TextBlock Classes="pane-label" Text="最后游戏时间"/>
                                    <TextBlock Grid.Column="1" Text="{Binding CreationTime}" Margin="12,0,0,0"/>
                                    <TextBlock Grid.Row="1" Classes="pane-label" Text="游戏版本"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding VersionId}" Margin="12,0,0,0"/>
                                    <TextBlock Grid.Row="2" Classes="pane-label" Text="标识符"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Id}" TextTrimming="CharacterEllipsis" Margin="12,0,0,0"/>
                                    <TextBlock Grid.Row="3" Classes="pane-label" Text="名称"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Name}" Margin="12,0,0,0"/>
                                </Grid>
                                <Button Classes="pane-danger" Content="确认移除" Command="{Binding DeleteInstanceCommand}"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,16,0,0">
            <Button Grid.Column="0" Classes="pane-secondary" Content="取消" Command="{Binding CancelCommand}"/>
            <Button Grid.Column="1" Classes="pane-primary" Command="{Binding SaveCommand}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                    <Image Source="/Assets/icos/save.png" Width="20" Height="20"/>
                    <TextBlock Text="保存"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
